<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ site.title }}</title>
    <meta name="description" content="{{ site.description }}">
    <meta property="og:title" content="{{ site.title }}">
    <meta property="og:description" content="{{ site.description }}">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <main class="page">

        <header class="masthead">
            <div class="wordmark">{{ site.wordmark }}</div>
            <div class="masthead-subtitle">{{ site.subtitle }}</div>
        </header>

        {{ content | safe }}

        <footer class="footer">
            <div class="wordmark">{{ site.wordmark }}</div>
            <div class="footer-links">
                <a href="mailto:{{ site.email }}">Email</a>
                <a href="{{ site.linkedin }}" target="_blank" rel="noopener">LinkedIn</a>
            </div>
        </footer>

    </main>

    <!-- Vercel Web Analytics -->
    <script defer src="/_vercel/insights/script.js"></script>
</body>
</html>
